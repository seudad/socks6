# Скопируйте в ../.env (корень репозитория рядом с docker-compose.yml)

# Прослушивание внутри контейнера (должен совпадать с правой частью SOCKS6_PUBLISH, если не меняете маппинг)
LISTEN=0.0.0.0:443

# TLS (пути внутри контейнера; по умолчанию том монтируется в /certs)
TLS_CERT=/certs/fullchain.pem
TLS_KEY=/certs/privkey.pem

# Reality (сгенерируйте: docker compose run --rm --entrypoint /usr/local/bin/socks6 socks6 --reality-generate-keys)
REALITY_DEST=www.google.com:443
REALITY_SECRET=PASTE_BASE64_32_BYTES
REALITY_SHORT_ID=PASTE_16_HEX_CHARS
REALITY_SERVER_NAMES=www.google.com

# Авторизация SOCKS (один пользователь или файл)
AUTH=user:change_me
# AUTH_FILE=/config/users.txt

# Опционально
# SOCKS6_SNI=www.google.com
# SNI_EXCLUDE_FILE=/config/sni-exclude.txt
# REALITY_MAX_TIME_DIFF=3600
# SOCKS6_TLS_FLEX=false
# RUST_LOG=socks6=info

# Доп. аргументы бинарника socks6
# SOCKS6_EXTRA_ARGS=

# compose: порт на хосте (левая часть проброса)
SOCKS6_PUBLISH=443
SOCKS6_CERT_DIR=./certs

# Клиент socks6-client в контейнере: docker/client.env.example → .env.client
# Запуск сервера и клиента: docker compose --profile client up -d --build
