# Скопируйте в .env.client в корне репозитория (рядом с docker-compose.yml)

# Локальный SOCKS5: внутри контейнера слушаем 1080 (сопоставьте с CLIENT_PUBLISH)
CLIENT_LISTEN=0.0.0.0:1080

# Хост:порт сервера Reality. В одном compose — имя сервиса:
CLIENT_SERVER=socks6:443
# С хоста — IP VPS и порт, например: socks6:443

# SNI для TLS (как --reality-server-names на сервере)
CLIENT_SERVER_NAME=www.google.com

CLIENT_SECRET=PASTE_BASE64_32_BYTES
CLIENT_SHORT_ID=PASTE_16_HEX_CHARS

# Если на socks6 включён --auth
# CLIENT_AUTH=user:change_me

# Опционально
# CLIENT_MAX_TLS=12
# CLIENT_AUTH_TIME_OFFSET=0
# SOCKS6_CLIENT_MAX_TLS=12
# SOCKS6_AUTH_TIME_OFFSET_SECS=0
# RUST_LOG=socks6_client=info
# CLIENT_EXTRA_ARGS=

# compose: порт на хосте (левая часть проброса)
CLIENT_PUBLISH=1080
